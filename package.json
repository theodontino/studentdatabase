{
  "name": "chem-track-ai",
  "version": "0.19.1",
  "license": "AGPL-3.0-only",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset --force && npm run db:seed",
    "db:backup": "npx tsx scripts/db-backup.ts",
    "db:archive": "npm run db:backup",
    "db:verify-backup": "npx tsx scripts/db-verify-backup.ts",
    "db:restore": "npx tsx scripts/db-restore.ts",
    "db:maintain": "npx tsx scripts/db-maintain.ts",
    "import:wecom": "npx tsx scripts/import-wecom-communications.ts",
    "docs:generate": "node --import tsx scripts/generate-docs.ts",
    "docs:check": "node --import tsx scripts/generate-docs.ts --check",
    "privacy:check": "node --import tsx scripts/privacy-check.ts",
    "test": "node --import tsx scripts/run-isolated-tests.ts vitest-run",
    "test:watch": "node --import tsx scripts/run-isolated-tests.ts vitest-watch",
    "test:coverage": "node --import tsx scripts/run-isolated-tests.ts vitest-coverage",
    "test:e2e": "node --import tsx scripts/run-isolated-tests.ts playwright"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next": "16.2.10",
    "openai": "^6.41.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "hono": "4.12.30",
    "postcss": "8.5.19"
  }
}
