generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 0. 班级（v0.10: 独立表，替换 Student.class / ClassSession.class 自由字符串）
model Class {
  id    String @id @default(cuid())
  code  String @unique   // 班级编号，如 "G3-01"，必填
  name  String?          // 班级名称，如 "高三(1)班"，可空

  students Student[]
  sessions ClassSession[]
}

// 1. 学生基础档案
model Student {
  id         String   @id @default(cuid())
  name       String
  classId    String
  studentId  String   @unique
  gender     String   // "男" | "女"
  labels     String   @default("[]") // JSON array, e.g. ["#逻辑强","#敏感"]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  class           Class             @relation(fields: [classId], references: [id])
  sessionMetrics  SessionMetric[]
  events          Event[]
  communications  Communication[]
  attendances     Attendance[]
}

// 2. 课次四维评分（每课次独立评分，sessionId 可空用于无课次场景）
model SessionMetric {
  id        String   @id @default(cuid())
  studentId String
  date      String   // YYYY-MM-DD，冗余字段（sessionId 可空时仍需直接绑定日期）
  scoreA    Int      // 0-5
  scoreB    Int      // 0-5
  scoreC    Int      // 0-5
  scoreD    Int      @default(3) // 0-5，考勤自动计算
  operator  String   // "quick-score" | "nl-review" | "teacher" | "system"
  sessionId String?  // 关联课次（可空，NL输入等无课次场景为null）
  createdAt DateTime @default(now())

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session ClassSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId])
}

// 2b. 评分历史存档（更新前备份，追加不覆盖）
model SessionMetricHistory {
  id          String   @id @default(cuid())
  metricId    String   // 原 SessionMetric.id
  studentId   String
  date        String
  scoreA      Int
  scoreB      Int
  scoreC      Int
  scoreD      Int
  operator    String
  sessionId   String?
  archivedAt  DateTime @default(now())
  changeType  String   // "update" | "delete"
}

// 3. 关键事件记录（绑定课次，日期从 ClassSession.date 获取）
model Event {
  id          String   @id @default(cuid())
  studentId   String
  sessionId   String   // 关联课次（必填）
  type        String   // "课堂表现" | "测验成绩" | "心理状态" | "家校沟通"
  description String
  rawText     String   // 原始输入文本片段
  createdAt   DateTime @default(now())

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId, description])
}

// 4. 家校沟通记录（绑定课次）
model Communication {
  id        String   @id @default(cuid())
  studentId String
  sessionId String   // 关联课次（必填）
  target    String   // 沟通对象，如 "父亲"、"母亲"
  summary   String   // 内容摘要
  createdAt DateTime @default(now())

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// 5. 待复核草案
model DraftRecord {
  id           String   @id @default(cuid())
  rawText      String
  parsedResult String   // JSON
  reviewResult String?  // JSON
  status       String   @default("pending") // "pending" | "confirmed" | "rejected"
  sessionCode  String?  // v0.7: 关联课次编码（可选）
  studentId    String?  // v0.10: 解析时匹配到的 studentId
  createdAt    DateTime @default(now())
}

// 6. 学期
model Semester {
  id        String   @id @default(cuid())
  name      String   // "2024-2025学年第一学期"
  startDate String   // YYYY-MM-DD
  endDate   String   // YYYY-MM-DD
  createdAt DateTime @default(now())

  sessions ClassSession[]
}

// 7. 课次记录（v0.2 重构：编码体系 + 班级 + 学期序号）
model ClassSession {
  id             String   @id @default(cuid())
  code           String   @unique         // YYYYMMDDNN，全局唯一标识
  semesterId     String
  semesterNumber Int                       // 学期内序号（1,2,3...），增删后应用层重排
  date           String                    // YYYY-MM-DD，冗余，从 code 推导方便索引
  classId        String?                   // 班级 FK；null = 全校
  createdAt      DateTime @default(now())

  semester    Semester         @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  class       Class?           @relation(fields: [classId], references: [id])
  attendances Attendance[]
  sessionMetrics SessionMetric[]
  events         Event[]
  communications  Communication[]
}

// 9. 系统操作日志（v0.11）
model SystemLog {
  id         String   @id @default(cuid())
  action     String   // "score.updated" | "alert.triggered" | "student.deleted" | "session.created" | "session.deleted" | "data.exported"
  targetType String   // "Student" | "Session" | "Draft" | "Class" | "System"
  targetId   String?  // 关联实体 id
  targetName String?  // 冗余：便于前端不 join 就能展示
  detail     String   @default("{}") // JSON，存储变更前后值等详情
  createdAt  DateTime @default(now())
}

// 8. 考勤记录
model Attendance {
  id        String   @id @default(cuid())
  sessionId String
  studentId String
  present   Boolean  @default(true)
  createdAt DateTime @default(now())

  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}
